# Neon PostgreSQL — copie a connection string do painel Neon (Connect)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth.js
AUTH_SECRET="gere-com-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Plataforma SaaS — administrador master (seu e-mail, separado por vírgula se houver mais)
SUPER_ADMIN_EMAILS="seu@email.com"

# Cadastro público em /register — deixe false em produção (você cria empresas em /platform)
ALLOW_PUBLIC_REGISTRATION="false"
